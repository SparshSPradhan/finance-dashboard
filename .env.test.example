# Copy to `.env.test` and adjust credentials/host if needed.
# Jest loads this in `tests/globalSetup.cjs` before `prisma migrate deploy`.
# `tests/setupEnv.ts` uses TEST_DATABASE_URL first, then DATABASE_URL, then the default below.

TEST_DATABASE_URL=postgresql://<USERNAME>:<PASSWORD>@localhost:5432/finance_dashboard_test?schema=public

JWT_SECRET=your_test_secret_key
BCRYPT_SALT_ROUNDS=10
